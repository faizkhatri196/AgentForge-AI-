# Server Port Configuration
PORT=5000

# JSON Web Token secret key (used for hashing user session hashes)
JWT_SECRET=your_jwt_secret_key

# MongoDB Connection String (used by Prisma ORM)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name?retryWrites=true&w=majority"

# Redis Cache URL
REDIS_URL="redis://localhost:6379"

# Qdrant Vector DB Host URL
QDRANT_URL="http://localhost:6333"

# Optional Global Keys (Users can also save keys dynamically inside the Settings dashboard)
OPENAI_API_KEY=""
GITHUB_TOKEN=""
