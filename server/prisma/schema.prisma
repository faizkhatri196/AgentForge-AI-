datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String
  name           String
  role           String         @default("Member") // Admin, Member
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  memberships    Member[]
}

model Organization {
  id             String         @id @default(uuid())
  name           String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  members        Member[]
  projects       Project[]
  apiKeys        ApiKey[]
  billing        Billing?
}

model Member {
  id             String         @id @default(uuid())
  role           String         @default("Member") // Owner, Admin, Member
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
}

model Project {
  id             String         @id @default(uuid())
  name           String
  prompt         String
  status         String         @default("Planning") // Planning, Designing, Coding, Testing, Complete
  progress       Int            @default(0)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  agents         Agent[]
  tasks          Task[]
  logs           Log[]
}

model Agent {
  id             String         @id @default(uuid())
  roleType       String         // CEO, PM, Architect, UI_Designer, Engineer, QA, DevOps
  name           String
  systemPrompt   String
  model          String         // e.g. gpt-4o, claude-3-5-sonnet, gemini-1.5-pro
  status         String         @default("Idle") // Idle, Active, Blocked
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tokensUsed     Int            @default(0)
  cost           Float          @default(0.0)
  latency        Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Task {
  id             String         @id @default(uuid())
  title          String
  status         String         @default("Pending") // Pending, Running, Success, Failed
  assignedRole   String         // CEO, PM, Engineer, etc.
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Message {
  id             String         @id @default(uuid())
  projectId      String
  fromAgent      String         // sender role
  toAgent        String         // recipient role
  payload        String         // JSON text content
  createdAt      DateTime       @default(now())
}

model Memory {
  id             String         @id @default(uuid())
  projectId      String
  category       String         // ShortTerm, LongTerm, Semantic
  content        String
  vectorId       String?        // Reference to Qdrant vector point uuid
  createdAt      DateTime       @default(now())
}

model ApiKey {
  id             String         @id @default(uuid())
  provider       String         // openai, anthropic, gemini, groq, deepseek, etc.
  keyEncrypted   String
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, provider])
}

model Log {
  id             String         @id @default(uuid())
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent          String
  message        String
  type           String         @default("info") // info, success, warning, error
  createdAt      DateTime       @default(now())
}

model Billing {
  id             String         @id @default(uuid())
  organizationId String         @unique
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planTier       String         @default("Free") // Free, Team, Enterprise
  tokenCount     Int            @default(0)
  accumulatedCost Float          @default(0.0)
  updatedAt      DateTime       @updatedAt
}
